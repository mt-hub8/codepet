{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CodePet",
  "version": "0.0.0",
  "identifier": "dev.codepet.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodePet",
        "width": 420,
        "height": 360,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

