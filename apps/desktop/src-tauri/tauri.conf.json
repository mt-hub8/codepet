{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CodePet",
  "version": "0.6.0",
  "identifier": "dev.codepet.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CodePet",
        "width": 1120,
        "height": 760,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "shortDescription": "本地优先 AI 桌面伙伴",
    "longDescription": "CodePet 是一个本地优先的 AI 桌面伙伴。当前为 Local Alpha 版本。",
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
